        },
        {
          "term": "指数级增长",
          "explanation": "指增长速度与当前水平成正比，导致总量在固定时间内按固定倍数增加，形成加速上升曲线。"
        },
        {
          "term": "财政可持续性",
          "explanation": "指政府在长期内维持其财政政策（如债务水平）而不引发危机或需要大幅调整的能力。"
        }
      ]
    }
  },
