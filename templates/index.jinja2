<!DOCTYPE html>
<html lang="zh-CN" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Beacon - Decoding Global Trends</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        beacon: {
                            bg: '#0F172A',
                            card: '#1E293B',
                            accent: '#F59E0B',
                            text: '#F8FAFC',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #0F172A; color: #F8FAFC; }
        .masonry { columns: 1; }
        @media (min-width: 768px) { .masonry { columns: 2; } }
        @media (min-width: 1280px) { .masonry { columns: 4; } }
        .masonry-item { break-inside: avoid; margin-bottom: 1rem; }
        .blur-load { filter: blur(20px); transition: filter 0.5s ease, opacity 0.5s ease; }
        .blur-load.loaded { filter: none; }
        .modal-overlay { transition: opacity 0.3s ease; }
        .modal-content { transition: transform 0.3s ease, opacity 0.3s ease; }
        .lightbox { transition: opacity 0.3s ease; }
        .lightbox-img { max-width: 95vw; max-height: 95vh; object-fit: contain; cursor: zoom-out; }
        .modal-img { cursor: zoom-in; }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #1E293B; }
        ::-webkit-scrollbar-thumb { background: #475569; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #64748B; }
    </style>
    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "YOUR_CF_TOKEN"}'></script>
</head>
<body class="min-h-screen">
    <!-- Header -->
    <header class="sticky top-0 z-40 bg-beacon-bg/80 backdrop-blur-md border-b border-slate-800">
        <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-3 h-3 rounded-full bg-beacon-accent animate-pulse"></div>
                <h1 class="text-2xl font-bold tracking-tight">
                    <span class="text-beacon-accent">Beacon</span>
                    <span class="text-slate-400 text-sm ml-2 font-normal">Decoding Global Trends</span>
                </h1>
            </div>
            <div class="text-slate-500 text-sm">
                {{ posts | length }} Insights
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 py-8">
        {% if posts %}
        <div class="masonry">
            {% for post in posts %}
            <article class="masonry-item group cursor-pointer" onclick="openModal({{ loop.index0 }})">
                <div class="bg-beacon-card rounded-xl overflow-hidden border border-slate-800 hover:border-beacon-accent/50 transition-all duration-300 hover:shadow-lg hover:shadow-beacon-accent/10">
                    <!-- Image -->
                    <div class="relative overflow-hidden">
                        <img
                            src="{{ post.base64_blur }}"
                            data-src="{{ post.r2_image_url }}"
                            alt="{{ post.title }}"
                            class="w-full blur-load lazy-image"
                            loading="lazy"
                        >
                        <div class="absolute inset-0 bg-gradient-to-t from-beacon-card via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    </div>
                    <!-- Info -->
                    <div class="p-4">
                        <h2 class="text-sm font-semibold text-beacon-text leading-tight mb-2 group-hover:text-beacon-accent transition-colors duration-200">
                            {{ post.title }}
                        </h2>
                        <p class="text-xs text-slate-500">{{ post.pub_date[:10] }}</p>
                        {% if post.ai_analysis.core_insight %}
                        <p class="text-xs text-slate-400 mt-2 line-clamp-2">
                            {{ post.ai_analysis.core_insight }}
                        </p>
                        {% endif %}
                    </div>
                </div>
            </article>
            {% endfor %}
        </div>
        {% else %}
        <div class="flex items-center justify-center h-96">
            <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-slate-800 flex items-center justify-center">
                    <div class="w-3 h-3 rounded-full bg-beacon-accent animate-pulse"></div>
                </div>
                <p class="text-slate-500">No insights yet. The beacon is warming up...</p>
            </div>
        </div>
        {% endif %}
    </main>

    <!-- Modal Overlay -->
    <div id="modal-overlay" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden modal-overlay opacity-0" onclick="closeModal()">
        <div class="absolute inset-y-0 right-0 w-full max-w-3xl bg-beacon-bg border-l border-slate-800 overflow-y-auto modal-content translate-x-full" onclick="event.stopPropagation()">
            <!-- Close Button -->
            <button onclick="closeModal()" class="sticky top-4 float-right mr-4 z-10 w-10 h-10 rounded-full bg-slate-800/80 backdrop-blur flex items-center justify-center text-slate-400 hover:text-white hover:bg-slate-700 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>

            <!-- Modal Content -->
            <div id="modal-body" class="p-6 pt-16">
                <!-- Dynamic content injected by JS -->
            </div>
        </div>
    </div>

    <!-- Lightbox (fullscreen image viewer) -->
    <div id="lightbox" class="fixed inset-0 z-[60] bg-black/95 hidden lightbox opacity-0 flex items-center justify-center" onclick="closeLightbox()">
        <button onclick="closeLightbox()" class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full bg-white/10 backdrop-blur flex items-center justify-center text-white/70 hover:text-white hover:bg-white/20 transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <img id="lightbox-img" src="" alt="" class="lightbox-img rounded-lg shadow-2xl">
    </div>

    <!-- Footer -->
    <footer class="border-t border-slate-800 mt-16 py-8">
        <div class="max-w-7xl mx-auto px-4 text-center text-slate-600 text-xs">
            <p>Beacon &mdash; Decoding Global Trends</p>
            <p class="mt-1">Data sourced from Visual Capitalist. AI analysis powered by OpenAI.</p>
        </div>
    </footer>

    <script>
        // Posts data for modal
        const posts = {{ posts | tojson }};

        // Progressive image loading
        document.addEventListener('DOMContentLoaded', function() {
            const lazyImages = document.querySelectorAll('.lazy-image');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const img = entry.target;
                        const src = img.dataset.src;
                        if (src) {
                            const tempImg = new Image();
                            tempImg.onload = function() {
                                img.src = src;
                                img.classList.add('loaded');
                            };
                            tempImg.src = src;
                        }
                        observer.unobserve(img);
                    }
                });
            }, { rootMargin: '200px' });

            lazyImages.forEach(img => observer.observe(img));
        });

        // Modal functions
        function openModal(index) {
            const post = posts[index];
            const overlay = document.getElementById('modal-overlay');
            const content = overlay.querySelector('.modal-content');
            const body = document.getElementById('modal-body');

            const glossaryHtml = (post.ai_analysis.glossary || []).map(g =>
                `<div class="bg-slate-800/50 rounded-lg p-3">
                    <div class="text-beacon-accent font-semibold text-sm">${g.term}</div>
                    <div class="text-slate-400 text-xs mt-1">${g.explanation}</div>
                </div>`
            ).join('');

            const highlightsHtml = (post.ai_analysis.data_highlights || []).map(h =>
                `<li class="flex items-start gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-beacon-accent mt-1.5 flex-shrink-0"></span>
                    <span>${h}</span>
                </li>`
            ).join('');

            body.innerHTML = `
                <div class="space-y-6">
                    <img src="${post.r2_image_url || post.base64_blur}" alt="${post.title}" class="w-full rounded-xl shadow-2xl modal-img" onclick="openLightbox('${post.r2_image_url || post.base64_blur}')">
                    <div>
                        <h2 class="text-xl font-bold text-beacon-text mb-2">${post.title}</h2>
                        <a href="${post.original_url}" target="_blank" rel="noopener" class="text-xs text-slate-500 hover:text-beacon-accent transition-colors">View Original &rarr;</a>
                    </div>
                    <div class="bg-beacon-card rounded-xl p-5 border border-slate-800">
                        <h3 class="text-beacon-accent font-bold text-sm mb-2 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zm3-6a1 1 0 100-2 1 1 0 000 2zm-1 13a1 1 0 100-2 1 1 0 000 2z"/><path fill-rule="evenodd" d="M10 2a8 8 0 100 16 8 8 0 000-16zm0 14a6 6 0 110-12 6 6 0 010 12z" clip-rule="evenodd"/></svg>
                            Core Insight
                        </h3>
                        <p class="text-sm text-slate-300 leading-relaxed">${post.ai_analysis.core_insight}</p>
                    </div>
                    ${highlightsHtml ? `
                    <div class="bg-beacon-card rounded-xl p-5 border border-slate-800">
                        <h3 class="text-beacon-accent font-bold text-sm mb-3 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zm6-4a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zm6-3a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/></svg>
                            Key Data
                        </h3>
                        <ul class="text-sm text-slate-300 space-y-2 leading-relaxed">${highlightsHtml}</ul>
                    </div>` : ''}
                    <div class="bg-beacon-card rounded-xl p-5 border border-slate-800">
                        <h3 class="text-beacon-accent font-bold text-sm mb-2 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                            Deep Dive
                        </h3>
                        <p class="text-sm text-slate-300 leading-relaxed whitespace-pre-line">${post.ai_analysis.deep_dive}</p>
                    </div>
                    ${glossaryHtml ? `
                    <div>
                        <h3 class="text-beacon-accent font-bold text-sm mb-3 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/></svg>
                            Glossary
                        </h3>
                        <div class="grid gap-2">${glossaryHtml}</div>
                    </div>` : ''}
                </div>
            `;

            overlay.classList.remove('hidden');
            requestAnimationFrame(() => {
                overlay.style.opacity = '1';
                content.style.transform = 'translateX(0)';
            });
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            const overlay = document.getElementById('modal-overlay');
            const content = overlay.querySelector('.modal-content');
            overlay.style.opacity = '0';
            content.style.transform = 'translateX(100%)';
            setTimeout(() => {
                overlay.classList.add('hidden');
                document.body.style.overflow = '';
            }, 300);
        }

        // Lightbox functions
        function openLightbox(imgUrl) {
            const lightbox = document.getElementById('lightbox');
            const lbImg = document.getElementById('lightbox-img');
            lbImg.src = imgUrl;
            lightbox.classList.remove('hidden');
            requestAnimationFrame(() => { lightbox.style.opacity = '1'; });
        }

        function closeLightbox() {
            const lightbox = document.getElementById('lightbox');
            lightbox.style.opacity = '0';
            setTimeout(() => {
                lightbox.classList.add('hidden');
                document.getElementById('lightbox-img').src = '';
            }, 300);
        }

        // Close with Escape key (lightbox first, then modal)
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const lightbox = document.getElementById('lightbox');
                if (!lightbox.classList.contains('hidden')) {
                    closeLightbox();
                } else {
                    closeModal();
                }
            }
        });
    </script>
</body>
</html>
