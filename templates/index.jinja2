<!DOCTYPE html>
<html lang="zh-CN" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Beacon - Decoding Global Trends</title>
    <link rel="alternate" type="application/rss+xml" title="Beacon RSS Feed" href="/feed.xml">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        beacon: {
                            bg: '#0F172A',
                            card: '#1E293B',
                            accent: '#F59E0B',
                            text: '#F8FAFC',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #0F172A; color: #F8FAFC; }
        .masonry { columns: 1; }
        @media (min-width: 768px) { .masonry { columns: 2; } }
        @media (min-width: 1280px) { .masonry { columns: 4; } }
        .masonry-item { break-inside: avoid; margin-bottom: 1rem; }
        .blur-load { filter: blur(20px); transition: filter 0.5s ease, opacity 0.5s ease; }
        .blur-load.loaded { filter: none; }
        .modal-overlay { transition: opacity 0.3s ease; }
        .modal-content { transition: transform 0.3s ease, opacity 0.3s ease; }
        .lightbox { transition: opacity 0.3s ease; }
        .lightbox-img { max-width: 95vw; max-height: 95vh; object-fit: contain; cursor: zoom-out; }
        .modal-img { cursor: zoom-in; }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #1E293B; }
        ::-webkit-scrollbar-thumb { background: #475569; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #64748B; }
        .markdown-body h2 { font-size: 1rem; font-weight: 700; color: #F59E0B; margin-top: 1.25rem; margin-bottom: 0.5rem; }
        .markdown-body h2:first-child { margin-top: 0; }
        .markdown-body h3 { font-size: 0.875rem; font-weight: 600; color: #e2e8f0; margin-top: 0.75rem; margin-bottom: 0.35rem; }
        .markdown-body p { margin-bottom: 0.5rem; line-height: 1.6; }
        .markdown-body ul { list-style: disc; padding-left: 1.25rem; margin: 0.35rem 0 0.75rem; }
        .markdown-body table { width: 100%; border-collapse: collapse; font-size: 0.75rem; }
        .markdown-body th, .markdown-body td { border: 1px solid #334155; padding: 0.35rem 0.5rem; text-align: left; }
        .markdown-body th { background: #1e293b; color: #F59E0B; }
        .data-table-wrap table { width: 100%; border-collapse: collapse; font-size: 0.75rem; }
        .data-table-wrap th, .data-table-wrap td { border: 1px solid #334155; padding: 0.4rem 0.55rem; text-align: left; vertical-align: top; }
        .data-table-wrap th { background: #1e293b; color: #F59E0B; white-space: nowrap; }
        details > summary::-webkit-details-marker { display: none; }
    </style>
    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "YOUR_CF_TOKEN"}'></script>
</head>
<body class="min-h-screen">
    <!-- Header -->
    <header class="sticky top-0 z-40 bg-beacon-bg/80 backdrop-blur-md border-b border-slate-800">
        <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-4">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-center gap-3">
                    <div class="w-3 h-3 rounded-full bg-beacon-accent animate-pulse"></div>
                    <h1 class="text-2xl font-bold tracking-tight">
                        <span class="text-beacon-accent">Beacon</span>
                        <span class="text-slate-400 text-sm ml-2 font-normal">Decoding Global Trends</span>
                    </h1>
                </div>
                <div class="flex items-center gap-3">
                    <div class="text-slate-500 text-sm tabular-nums">
                        <span id="insight-visible">{{ posts | length }}</span> / <span id="insight-total">{{ posts | length }}</span> 条
                    </div>
                    <a href="/feed.xml" title="RSS 订阅" class="text-slate-500 hover:text-beacon-accent transition-colors" rel="noopener">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
                    </a>
                </div>
            </div>
            {% if posts %}
            <div class="flex flex-col sm:flex-row gap-3 sm:items-center">
                <label class="sr-only" for="filter-q">搜索</label>
                <input type="search" id="filter-q" autocomplete="off" placeholder="按标题或正文关键字搜索…"
                    class="w-full sm:flex-1 rounded-lg bg-slate-900/80 border border-slate-700 px-3 py-2 text-sm text-slate-200 placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-beacon-accent/40">
                <button type="button" id="filter-clear" class="shrink-0 rounded-lg border border-slate-600 px-3 py-2 text-xs text-slate-400 hover:bg-slate-800 hover:text-slate-200 transition-colors">清除搜索</button>
            </div>
            {% endif %}
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 py-8">
        {% if posts %}
        <div class="masonry" id="post-masonry">
            {% for post in posts %}
            <article class="masonry-item post-card group cursor-pointer"
                data-orig-index="{{ loop.index0 }}"
                data-search="{{ post.search_text | e }}"
                onclick="openModal(Number(this.dataset.origIndex))">
                <div class="bg-beacon-card rounded-xl overflow-hidden border border-slate-800 hover:border-beacon-accent/50 transition-all duration-300 hover:shadow-lg hover:shadow-beacon-accent/10">
                    <!-- Image -->
                    <div class="relative overflow-hidden">
                        <img
                            src="{{ post.base64_blur }}"
                            data-src="{{ post.r2_image_url }}{% if post.image_version %}?v={{ post.image_version }}{% endif %}"
                            alt="{{ post.title }}"
                            class="w-full blur-load lazy-image"
                            loading="lazy"
                        >
                        <div class="absolute inset-0 bg-gradient-to-t from-beacon-card via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    </div>
                    <!-- Info -->
                    <div class="p-4">
                        <h2 class="text-sm font-semibold text-beacon-text leading-tight mb-2 group-hover:text-beacon-accent transition-colors duration-200">
                            {{ post.title }}
                        </h2>
                        <p class="text-xs text-slate-500">{{ post.pub_date[:10] }}</p>
                        {% if post.ai_analysis and post.ai_analysis.core_insight %}
                        <p class="text-xs text-slate-400 mt-2 line-clamp-2">
                            {{ post.ai_analysis.core_insight }}
                        </p>
                        {% endif %}
                    </div>
                </div>
            </article>
            {% endfor %}
        </div>
        {% else %}
        <div class="flex items-center justify-center h-96">
            <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-slate-800 flex items-center justify-center">
                    <div class="w-3 h-3 rounded-full bg-beacon-accent animate-pulse"></div>
                </div>
                <p class="text-slate-500">No insights yet. The beacon is warming up...</p>
            </div>
        </div>
        {% endif %}
    </main>

    <!-- Modal Overlay -->
    <div id="modal-overlay" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden modal-overlay opacity-0" onclick="closeModal()">
        <div class="absolute inset-y-0 right-0 w-full max-w-3xl bg-beacon-bg border-l border-slate-800 overflow-y-auto modal-content translate-x-full" onclick="event.stopPropagation()">
            <!-- Close Button -->
            <button onclick="closeModal()" class="sticky top-4 float-right mr-4 z-10 w-10 h-10 rounded-full bg-slate-800/80 backdrop-blur flex items-center justify-center text-slate-400 hover:text-white hover:bg-slate-700 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>

            <!-- Modal Content -->
            <div id="modal-body" class="p-6 pt-16">
                <!-- Dynamic content injected by JS -->
            </div>
        </div>
    </div>

    <!-- Lightbox (fullscreen image viewer) -->
    <div id="lightbox" class="fixed inset-0 z-[60] bg-black/95 hidden lightbox opacity-0 flex items-center justify-center" onclick="closeLightbox()">
        <button onclick="closeLightbox()" class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full bg-white/10 backdrop-blur flex items-center justify-center text-white/70 hover:text-white hover:bg-white/20 transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <img id="lightbox-img" src="" alt="" class="lightbox-img rounded-lg shadow-2xl">
    </div>

    <!-- Footer -->
    <footer class="border-t border-slate-800 mt-16 py-8">
        <div class="max-w-7xl mx-auto px-4 text-center text-slate-600 text-xs space-y-1">
            <p>Powered by <a href="https://beacon.thetamind.ai" class="text-beacon-accent hover:underline">beacon.thetamind.ai</a></p>
            <p>Data sourced from <a href="https://www.visualcapitalist.com/" class="text-slate-500 hover:text-beacon-accent hover:underline" rel="noopener">Visual Capitalist</a>.</p>
            <p><a href="https://github.com/liu-kaining/Beacon" class="text-beacon-accent hover:underline" rel="noopener">GitHub 项目：liu-kaining/Beacon</a></p>
        </div>
    </footer>

    <script>
        const posts = {{ posts | tojson }};

        function esc(s) {
            return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function buildDataTablesHtml(tables) {
            if (!tables || !tables.length) return '';
            return tables.map(t => {
                const headers = t.headers || [];
                const rows = t.rows || [];
                const cap = t.caption ? `<div class="text-xs text-slate-500 mb-2">${esc(t.caption)}</div>` : '';
                const th = headers.map(h => `<th>${esc(h)}</th>`).join('');
                const tr = rows.map(row => `<tr>${(row || []).map(c => `<td>${esc(c)}</td>`).join('')}</tr>`).join('');
                return `<div class="data-table-wrap overflow-x-auto mb-4">${cap}<table><thead><tr>${th}</tr></thead><tbody>${tr}</tbody></table></div>`;
            }).join('');
        }

        function applyPostFilters() {
            const q = (document.getElementById('filter-q')?.value || '').trim().toLowerCase();
            const cards = document.querySelectorAll('.post-card');
            let n = 0;
            cards.forEach(card => {
                const hay = (card.dataset.search || '').toLowerCase();
                let ok = true;
                if (q && !hay.includes(q)) ok = false;
                card.classList.toggle('hidden', !ok);
                if (ok) n++;
            });
            const vis = document.getElementById('insight-visible');
            const tot = document.getElementById('insight-total');
            if (vis) vis.textContent = String(n);
            if (tot) tot.textContent = String(cards.length);
        }

        document.addEventListener('DOMContentLoaded', function() {
            const lazyImages = document.querySelectorAll('.lazy-image');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const img = entry.target;
                        const src = img.dataset.src;
                        if (src) {
                            const tempImg = new Image();
                            tempImg.onload = function() {
                                img.src = src;
                                img.classList.add('loaded');
                            };
                            tempImg.src = src;
                        }
                        observer.unobserve(img);
                    }
                });
            }, { rootMargin: '200px' });
            lazyImages.forEach(img => observer.observe(img));

            const fq = document.getElementById('filter-q');
            const clr = document.getElementById('filter-clear');
            if (fq) {
                fq.addEventListener('input', applyPostFilters);
                fq.addEventListener('change', applyPostFilters);
            }
            if (clr) clr.addEventListener('click', () => {
                if (fq) fq.value = '';
                applyPostFilters();
            });
        });

        function openModal(index) {
            const post = posts[index];
            if (!post) return;
            const ai = post.ai_analysis || {};
            const overlay = document.getElementById('modal-overlay');
            const content = overlay.querySelector('.modal-content');
            const body = document.getElementById('modal-body');

            const imgUrl = post.r2_image_url
                ? post.r2_image_url + (post.image_version ? (`?v=${post.image_version}`) : '')
                : post.base64_blur;

            const glossaryHtml = (ai.glossary || []).map(g =>
                `<div class="bg-slate-800/50 rounded-lg p-3">
                    <div class="text-beacon-accent font-semibold text-sm">${esc(g.term)}</div>
                    <div class="text-slate-400 text-xs mt-1">${esc(g.explanation)}</div>
                </div>`
            ).join('');

            const highlightsHtml = (ai.data_highlights || []).map(h =>
                `<li class="flex items-start gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-beacon-accent mt-1.5 flex-shrink-0"></span>
                    <span>${esc(h)}</span>
                </li>`
            ).join('');

            const tablesHtml = buildDataTablesHtml(ai.data_tables || []);
            const deepHtml = ai.deep_dive_html
                ? `<div class="markdown-body text-sm text-slate-300 leading-relaxed">${ai.deep_dive_html}</div>`
                : `<p class="text-sm text-slate-300 leading-relaxed whitespace-pre-line">${esc(ai.deep_dive || '')}</p>`;

            const sourceBlock = (post.content_html && String(post.content_html).trim())
                ? `<details class="bg-beacon-card rounded-xl border border-slate-800 group">
                    <summary class="cursor-pointer list-none px-5 py-3 text-sm text-beacon-accent font-semibold flex items-center gap-2">
                        <span class="transition-transform group-open:rotate-90 inline-block">▸</span>
                        原文数据表（RSS 提取）
                    </summary>
                    <div class="px-5 pb-5 overflow-x-auto markdown-body text-sm text-slate-300">${post.content_html}</div>
                </details>`
                : '';

            body.innerHTML = `
                <div class="space-y-6">
                    <img src="${esc(imgUrl)}" alt="${esc(post.title)}" class="w-full rounded-xl shadow-2xl modal-img" data-lb="${esc(imgUrl)}" onclick="openLightbox(this.dataset.lb)">
                    <div>
                        <h2 class="text-xl font-bold text-beacon-text mb-2">${esc(post.title)}</h2>
                        <a href="${esc(post.original_url)}" target="_blank" rel="noopener" class="text-xs text-slate-500 hover:text-beacon-accent transition-colors">View Original &rarr;</a>
                    </div>
                    <div class="bg-beacon-card rounded-xl p-5 border border-slate-800">
                        <h3 class="text-beacon-accent font-bold text-sm mb-2 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zm3-6a1 1 0 100-2 1 1 0 000 2zm-1 13a1 1 0 100-2 1 1 0 000 2z"/><path fill-rule="evenodd" d="M10 2a8 8 0 100 16 8 8 0 000-16zm0 14a6 6 0 110-12 6 6 0 010 12z" clip-rule="evenodd"/></svg>
                            Core Insight
                        </h3>
                        <p class="text-sm text-slate-300 leading-relaxed">${esc(ai.core_insight)}</p>
                    </div>
                    ${highlightsHtml ? `
                    <div class="bg-beacon-card rounded-xl p-5 border border-slate-800">
                        <h3 class="text-beacon-accent font-bold text-sm mb-3 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zm6-4a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zm6-3a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/></svg>
                            Key Data（要点）
                        </h3>
                        <ul class="text-sm text-slate-300 space-y-2 leading-relaxed">${highlightsHtml}</ul>
                    </div>` : ''}
                    ${tablesHtml ? `
                    <div class="bg-beacon-card rounded-xl p-5 border border-slate-800">
                        <h3 class="text-beacon-accent font-bold text-sm mb-3 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zm6-4a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zm6-3a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/></svg>
                            完整数据表
                        </h3>
                        ${tablesHtml}
                    </div>` : ''}
                    ${sourceBlock}
                    <div class="bg-beacon-card rounded-xl p-5 border border-slate-800">
                        <h3 class="text-beacon-accent font-bold text-sm mb-2 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                            Deep Dive
                        </h3>
                        ${deepHtml}
                    </div>
                    ${glossaryHtml ? `
                    <div>
                        <h3 class="text-beacon-accent font-bold text-sm mb-3 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/></svg>
                            Glossary
                        </h3>
                        <div class="grid gap-2">${glossaryHtml}</div>
                    </div>` : ''}
                </div>
            `;

            overlay.classList.remove('hidden');
            requestAnimationFrame(() => {
                overlay.style.opacity = '1';
                content.style.transform = 'translateX(0)';
            });
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            const overlay = document.getElementById('modal-overlay');
            const content = overlay.querySelector('.modal-content');
            overlay.style.opacity = '0';
            content.style.transform = 'translateX(100%)';
            setTimeout(() => {
                overlay.classList.add('hidden');
                document.body.style.overflow = '';
            }, 300);
        }

        // Lightbox functions
        function openLightbox(imgUrl) {
            const lightbox = document.getElementById('lightbox');
            const lbImg = document.getElementById('lightbox-img');
            lbImg.src = imgUrl;
            lightbox.classList.remove('hidden');
            requestAnimationFrame(() => { lightbox.style.opacity = '1'; });
        }

        function closeLightbox() {
            const lightbox = document.getElementById('lightbox');
            lightbox.style.opacity = '0';
            setTimeout(() => {
                lightbox.classList.add('hidden');
                document.getElementById('lightbox-img').src = '';
            }, 300);
        }

        // Close with Escape key (lightbox first, then modal)
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const lightbox = document.getElementById('lightbox');
                if (!lightbox.classList.contains('hidden')) {
                    closeLightbox();
                } else {
                    closeModal();
                }
            }
        });
    </script>
</body>
</html>
